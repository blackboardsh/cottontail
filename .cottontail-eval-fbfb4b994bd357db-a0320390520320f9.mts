import { setTimeout, clearTimeout } from "node:timers";\nconst t=setTimeout(()=>console.log("FIRED"),1);\nconst s=(+t).toString();\nconst units=new DataView(new ArrayBuffer(2*s.length));\nfor(let i=0;i<s.length;i++)units.setUint16(2*i,s.charCodeAt(i),true);\nconst u=new TextDecoder("utf-16le").decode(units);\nconsole.log(JSON.stringify(u), /^(?:0|[1-9][0-9]*)$/.test(u), +t);\nclearTimeout(u);\nconsole.log("cleared",t._destroyed);\nglobalThis.setTimeout(()=>console.log("done"),5);