# test-run artifacts inside the upstream snapshot
# The copied Bun snapshot owns only these five entries at its root. Upstream
# tests frequently write arbitrary filenames beside them.
compat/upstream/bun/*/*
!compat/upstream/bun/*/LICENSE.md
!compat/upstream/bun/*/manifest.json
!compat/upstream/bun/*/src/
!compat/upstream/bun/*/status.json
!compat/upstream/bun/*/test/
!compat/upstream/bun/*/packages/
compat/upstream/bun/*/packages/*
!compat/upstream/bun/*/packages/bun-native-bundler-plugin-api/
compat/upstream/bun/*/packages/bun-native-bundler-plugin-api/*
!compat/upstream/bun/*/packages/bun-native-bundler-plugin-api/bundler_plugin.h
compat/upstream/**/Heap.*.heapsnapshot
compat/upstream/**/Heap-*.heapsnapshot
compat/upstream/**/.cottontail-compat-*
compat/upstream/**/.cottontail-compile-cache/
compat/upstream/**/fstest*/
compat/upstream/**/.verdaccio-db.json
compat/upstream/bun/*/app
compat/upstream/bun/*/app.exe
compat/upstream/bun/*/a.txt
compat/upstream/bun/*/b.txt
compat/upstream/bun/*/append_output.txt
compat/upstream/bun/*/report.json
compat/upstream/bun/*/undefined
compat/upstream/bun/*/app.map
compat/upstream/bun/*/chunk-*.js.map
compat/upstream/bun/*/entry
compat/upstream/bun/*/entry.map
compat/upstream/bun/*/nosourcemap_entry
compat/upstream/bun/*/test*file.db
compat/upstream/bun/*/*.db*
compat/upstream/bun/*/sqlite:*

# compile-mode diagnostics emitted at the repository root
/chunk-*.js.map
/entry
/entry.map
/tests/js/fixtures/debug-compile-split/
